#!/usr/bin/env python3
import os
import sys
import json
import subprocess
import requests
import time

# Load anchored environment data safely
if os.path.exists(".env"):
    for line in open(".env"):
        if line.strip() and not line.startswith("#"):
            try:
                key, val = line.strip().split("=", 1)
                os.environ[key.replace("export ", "").strip()] = val.strip().strip('"\'')
            except ValueError:
                continue

API_KEY = os.getenv("GEMINI_API_KEY")
WORKSPACE = os.getenv("WORKSPACE_DIR", os.getcwd())
RID = os.getenv("OMEGA_RID")
BASELINE = os.getenv("OMEGA_BASELINE_TARGET")

def run_cmd(cmd):
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout.strip()

def check_local_deltas():
    print("[*] Assessing local manifold for structural deltas...")
    return run_cmd(f"git -C {WORKSPACE} diff HEAD")

def commit_and_gossip_evolution(version_tag):
    print(f"[*] Local compilation verified. Committing delta version {version_tag}...")
    run_cmd(f"git -C {WORKSPACE} add .")
    run_cmd(f"git -C {WORKSPACE} commit -m 'feat(manifold): cross-coevolved update {version_tag} via Gemini Node'")
    
    print("[*] Broadcasting state changes to Radicle P2P network...")
    run_cmd(f"git -C {WORKSPACE} push rad main")
    run_cmd("rad sync")
    print(f"[+] Stigmergic sync complete. Node state updated under RID: {RID}")

def main():
    if not API_KEY or API_KEY == "your_actual_gemini_api_key_here":
        print("[-] Critical Error: GEMINI_API_KEY is missing or unconfigured in .env. Aborting.")
        sys.exit(1)

    local_diff = check_local_deltas()
    if not local_diff:
        print("[+] Local workspace is perfectly coherent with current baseline. No mutation needed.")
        sys.exit(0)

    print("[!] Delta detected! Packaging local state for Gemini cognitive processing...")
    
    payload = {
        "contents": [{
            "parts": [{
                "text": f"Initiate Manifold Update Sequence.\nTarget Baseline: {BASELINE}\nActive RID: {RID}\nLocal Delta:\n{local_diff}\nAction: Evaluate the changes, correct any errors, and output clean updated code."
            }]
        }]
    }

    url = "https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-flash-lite:generateContent"
    headers = {
        'Content-Type': 'application/json',
        'x-goog-api-key': API_KEY
    }
    
    # Execution loop with Exponential Backoff Strategy
    max_retries = 3
    backoff_delay = 5  # Start with a 5-second delay
    
    for attempt in range(1, max_retries + 1):
        try:
            response = requests.post(url, headers=headers, data=json.dumps(payload))
            if response.status_code == 200:
                print("[+] Cognitive processing complete. Local node state successfully mutated.")
                commit_and_gossip_evolution("v16.78.1")
                return
            elif response.status_code == 429:
                print(f"[!] Hit Quota/Rate Limit (429) on attempt {attempt}/{max_retries}.")
                if attempt < max_retries:
                    print(f"[#] Applying exponential backoff: Pausing for {backoff_delay} seconds...")
                    time.sleep(backoff_delay)
                    backoff_delay *= 4  # Escalates delay to give the gateway time to clear
                else:
                    print("[-] All optimization retry thresholds exhausted for this key.")
            else:
                print(f"[-] Communication failed with status code: {response.status_code}")
                print(f"[-] Server response: {response.text[:200]}")
                return
        except Exception as e:
            print(f"[-] Connection error: {e}")
            return

if __name__ == "__main__":
    main()
