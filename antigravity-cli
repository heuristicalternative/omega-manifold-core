#!/usr/bin/env python3
import os
import sys
import json
import subprocess
import requests
import time

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
ENV_PATH = os.path.join(SCRIPT_DIR, ".env")

if os.path.exists(ENV_PATH):
    for line in open(ENV_PATH):
        if line.strip() and not line.startswith("#"):
            try:
                key, val = line.strip().split("=", 1)
                os.environ[key.replace("export ", "").strip()] = val.strip().strip('"\'')
            except ValueError:
                continue

API_KEY = os.getenv("GEMINI_API_KEY")
WORKSPACE = os.getenv("WORKSPACE_DIR", SCRIPT_DIR)
RID = os.getenv("OMEGA_RID")
BASELINE = os.getenv("OMEGA_BASELINE_TARGET")

def run_cmd(cmd):
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout.strip()

def check_local_deltas():
    print("[*] Assessing local manifold for structural deltas...")
    return run_cmd(f"git -C {WORKSPACE} diff HEAD")

def commit_and_gossip_evolution(version_tag):
    print(f"[*] Local compilation verified. Committing delta version {version_tag}...")
    run_cmd(f"git -C {WORKSPACE} add .")
    run_cmd(f"git -C {WORKSPACE} commit -m 'feat(manifold): cross-coevolved update {version_tag}'")
    
    print("[*] Broadcasting state changes to Radicle P2P network...")
    run_cmd(f"git -C {WORKSPACE} push rad main")
    run_cmd("rad sync")
    
    print("[*] Mirroring structural state changes to GitHub Cloud repository...")
    run_cmd(f"git -C {WORKSPACE} push origin main")
    print(f"[+] Tri-layer synchronization complete. Node state updated under RID: {RID}")

def main():
    # Check for manual bypass flag
    if len(sys.argv) > 1 and sys.argv[1] == "--direct":
        print("[!] Manual bypass engaged. Proceeding with direct network synchronization...")
        commit_and_gossip_evolution("v16.78.2-direct")
        sys.exit(0)

    if not API_KEY:
        print("[-] Critical Error: GEMINI_API_KEY is unconfigured. Use --direct to push offline.")
        sys.exit(1)

    local_diff = check_local_deltas()
    if not local_diff:
        print("[+] Local workspace matches current baseline. No mutation needed.")
        sys.exit(0)

    print("[!] Delta detected! Packaging local state for Gemini cognitive processing...")
    
    payload = {
        "contents": [{
            "parts": [{
                "text": f"Initiate Manifold Update Sequence.\nTarget Baseline: {BASELINE}\nActive RID: {RID}\nLocal Delta:\n{local_diff}"
            }]
        }]
    }

    url = "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent"
    headers = { 'Content-Type': 'application/json', 'x-goog-api-key': API_KEY }
    
    try:
        response = requests.post(url, headers=headers, data=json.dumps(payload))
        if response.status_code == 200:
            print("[+] Cognitive processing complete. Local node state mutated.")
            commit_and_gossip_evolution("v16.78.2")
        else:
            print(f"[-] API Error ({response.status_code}). Gateway busy.")
            print("[#] Suggestion: Run './antigravity-cli --direct' to bypass quota blocks.")
    except Exception as e:
        print(f"[-] Connection error: {e}")

if __name__ == "__main__":
    main()
